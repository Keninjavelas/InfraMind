{
  "name": "inframind",
  "displayName": "InfraMind",
  "description": "AI-native Infrastructure Intelligence for Modern DevOps",
  "version": "0.1.0",
  "publisher": "aryankapoor-keninjavelas",
  "author": {
    "name": "Aryan Kapoor / Keninjavelas"
  },
  "icon": "assets/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Keninjavelas/InfraMind.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Linters",
    "Machine Learning",
    "Programming Languages"
  ],
  "keywords": [
    "terraform",
    "kubernetes",
    "docker",
    "infrastructure",
    "security",
    "ai",
    "diagrams"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "inframind.analyzeWorkspace",
        "title": "InfraMind: Analyze Workspace"
      },
      {
        "command": "inframind.visualizeArchitecture",
        "title": "InfraMind: Visualize Architecture"
      },
      {
        "command": "inframind.openSettings",
        "title": "InfraMind: Open Settings"
      },
      {
        "command": "inframind.refreshSidebar",
        "title": "InfraMind: Refresh Sidebar",
        "icon": "$(refresh)"
      }
    ],
    "viewContainers": {
      "activitybar": [
        {
          "id": "inframind",
          "title": "InfraMind",
          "icon": "assets/activity-icon.svg"
        }
      ]
    },
    "views": {
      "inframind": [
        {
          "id": "inframind.securityView",
          "name": "Security Risks",
          "icon": "assets/activity-icon.svg"
        },
        {
          "id": "inframind.architectureView",
          "name": "Architecture Topology"
        },
        {
          "id": "inframind.actionsView",
          "name": "Quick Actions"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "inframind.refreshSidebar",
          "when": "viewContainer == inframind",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "InfraMind",
      "properties": {
        "inframind.provider": {
          "type": "string",
          "default": "groq",
          "description": "The AI provider to use for explanations and reviews."
        },
        "inframind.apiKey": {
          "type": "string",
          "default": "",
          "description": "User-supplied API Key for AI operations (overrides server-side keys)."
        },
        "inframind.backendUrl": {
          "type": "string",
          "default": "https://inframind-hqrl.onrender.com",
          "description": "The URL of the InfraMind backend service."
        },
        "inframind.model": {
          "type": "string",
          "default": "",
          "description": "Specific AI model to use (e.g., gpt-4o, claude-3-5-sonnet, llama3)."
        },
        "inframind.ollamaHost": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "The host URL for local Ollama instance."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "lint": "eslint src --ext ts",
    "test": "node ./test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "eslint": "^8.47.0",
    "typescript": "^5.1.6",
    "ts-loader": "^9.4.4",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4"
  }
}
